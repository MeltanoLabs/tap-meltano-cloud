# MeltanoCloud Configuration
# Copy this file to .env and fill in your actual values

# Required: Authentication token for the API service
TAP_MELTANO_CLOUD_AUTH_TOKEN=your_auth_token_here

# Optional: The earliest record date to sync (ISO format)
TAP_MELTANO_CLOUD_START_DATE=2023-01-01T00:00:00Z

# Optional: API URL (defaults to https://api.mysample.com)
TAP_MELTANO_CLOUD_API_URL=https://app.matatika.com/api

# Optional: Comma-separated list of workspace IDs to sync (JSON array format)
# When set, only those workspaces are fetched; omit to sync all accessible workspaces
# TAP_MELTANO_CLOUD_WORKSPACE_IDS=["workspace-uuid-1","workspace-uuid-2"]
